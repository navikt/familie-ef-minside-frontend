{
  "name": "familie-ef-minside-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint:eslint": "eslint './src/**/*.{ts,tsx}' --max-warnings=0",
    "lint": "npm run lint:eslint && npm run typecheck",
    "build:server": "tsc --build server/tsconfig.json --verbose",
    "start:dev": "npm run build:server && NODE_ENV=development ENV=localhost node server/backend/server-lokal.js",
    "start:preprod": "npm run build:server && NODE_ENV=development BRUK_DEV_API=true ENV=localhost node server/backend/server-lokal.js",
    "test": "vitest run --exclude '**/build/**'"
  },
  "dependencies": {
    "@navikt/aksel-icons": "8.11.1",
    "@navikt/ds-css": "8.11.1",
    "@navikt/ds-react": "8.11.1",
    "@navikt/ds-tokens": "8.11.1",
    "@navikt/nav-dekoratoren-moduler": "4.2.2",
    "@types/react": "19.2.17",
    "axios": "1.17.0",
    "cookie-parser": "1.4.7",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "eslint": "10.4.1",
    "express": "5.2.1",
    "http-proxy-middleware": "4.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.17.0",
    "styled-components": "6.4.2",
    "uuid": "14.0.0",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "^25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
